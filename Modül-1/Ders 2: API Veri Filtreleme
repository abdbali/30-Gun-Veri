<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ders 2: API Veri Filtreleme</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 font-sans text-gray-800 antialiased min-h-screen flex flex-col">

<header class="bg-white border-b border-gray-200 py-6 px-8 shadow-xs">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
    <div>
      <span class="text-xs font-semibold text-blue-600 tracking-wider uppercase">Modül 1: Veri Okuryazarlığı • Ders 2</span>
      <h1 class="text-2xl font-bold text-gray-900 mt-1">API Nesne Yapısı ve Koşullu Filtreleme</h1>
    </div>
    <div class="bg-blue-50 text-blue-700 px-4 py-2 rounded-lg font-medium text-sm border border-blue-100">
      Doğru Filtreleme: <span id="score" class="font-bold">0</span> / 6
    </div>
  </div>
</header>

<main class="flex-1 max-w-7xl w-full mx-auto p-6 grid grid-cols-1 lg:grid-cols-12 gap-6">

  <div class="lg:col-span-4 bg-white p-6 rounded-2xl border border-gray-200 shadow-xs flex flex-col justify-between gap-6">
    <div>
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Algoritma Mantığı</h2>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">
        API'lerden (Uygulama Programlama Arayüzü) gelen veriler genellikle iç içe geçmiş nesneler (Object) halindedir. Bu ham verileri yapay zeka modellerine göndermeden önce, iş kurallarına göre filtreleyip temizlememiz gerekir.
      </p>

      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-xl space-y-3 mb-4">
        <h3 class="text-xs font-bold text-blue-900 uppercase tracking-wider">Kodlama Yol Haritası</h3>
        <p class="text-xs text-blue-800 leading-relaxed">
          Yandaki editörün içine sırayla şu mantığı kurmanız bekleniyor:
        </p>
        <ol class="text-xs text-blue-800 list-decimal list-inside space-y-2 font-medium">
          <li>Gelen nesnenin durumunu kontrol edin. Eğer `kullanici.aktif` değeri `false` ise, geriye doğrudan `false` döndürün.</li>
          <li>Eğer kullanıcı aktifse, yaşını kontrol edin. `kullanici.yas` değeri 18 veya daha büyükse geriye `true` döndürün.</li>
          <li>Yaşı 18'den küçük olan aktif kullanıcılar için geriye `false` döndürün.</li>
        </ol>
      </div>

      <div class="bg-amber-50 border-l-4 border-amber-500 p-4 rounded-r-xl">
        <h3 class="text-xs font-bold text-amber-900 uppercase tracking-wider mb-1">Kullanılacak Sözdizimi</h3>
        <pre class="text-[11px] font-mono text-amber-950 leading-relaxed">if (kullanici.aktif === false) {
    return false;
} else if (kullanici.yas >= 18) {
    // kodunuz...
}</pre>
      </div>
    </div>

    <div id="feedback" class="p-4 rounded-xl text-sm font-medium text-center hidden"></div>
  </div>

  <div class="lg:col-span-5 bg-gray-900 rounded-2xl border border-gray-800 shadow-lg flex flex-col overflow-hidden min-h-[500px]">
    <div class="bg-gray-950 px-4 py-3 border-b border-gray-800 flex justify-between items-center">
      <span class="text-xs font-semibold text-gray-400 font-mono">api_filter.js</span>
      <span class="w-2 h-2 rounded-full bg-blue-500"></span>
    </div>

    <div class="flex-1 p-4 font-mono text-xs text-gray-300 flex flex-col bg-gray-950">
      <div class="text-gray-500 mb-2">// Fonksiyon icerisine if-else bloklarinizi yazin.</div>
      <div class="text-blue-400 font-semibold text-sm">function <span class="text-green-400">apiVerisiniFiltrele</span>(kullanici) {</div>

      <textarea id="code-input" class="w-full flex-1 bg-gray-900/40 border border-gray-800 focus:border-blue-500 text-green-400 p-4 font-mono text-xs rounded-lg focus:outline-hidden resize-none my-2 leading-loose tracking-wide" spellcheck="false" placeholder="// 1. Adimdan baslayarak kodunuzu buraya yazin..."></textarea>

      <div class="text-blue-400 font-semibold text-sm">}</div>
    </div>

    <div class="p-4 bg-gray-950 border-t border-gray-800 flex gap-3">
      <button id="help-btn" class="bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium text-xs px-4 py-3 rounded-xl transition cursor-pointer">
        İpucu Ekle
      </button>
      <button id="run-code-btn" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-medium text-xs px-5 py-3 rounded-xl transition cursor-pointer text-center font-bold uppercase tracking-wider">
        Derle ve Testleri Başlat
      </button>
    </div>
  </div>

  <div class="lg:col-span-3 flex flex-col gap-4">

    <div class="bg-white p-4 rounded-2xl border border-gray-200 shadow-xs">
      <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Test Edilecek Ham Veri Seti</h3>
      <div class="space-y-1 font-mono text-[10px] text-gray-600 max-h-[180px] overflow-y-auto">
        <div class="p-1 bg-gray-50 rounded">Ahmet: {yas: 24, aktif: true}</div>
        <div class="p-1 bg-gray-50 rounded">Mehmet: {yas: 16, aktif: true}</div>
        <div class="p-1 bg-gray-50 rounded">Ayşe: {yas: 32, aktif: false}</div>
        <div class="p-1 bg-gray-50 rounded">Can: {yas: 19, aktif: true}</div>
        <div class="p-1 bg-gray-50 rounded">Elif: {yas: 17, aktif: false}</div>
        <div class="p-1 bg-gray-50 rounded">Zeynep: {yas: 45, aktif: true}</div>
      </div>
    </div>

    <div class="flex-1 bg-white border border-gray-200 p-4 rounded-2xl flex flex-col shadow-2xs">
      <h3 class="font-bold text-gray-800 text-xs uppercase tracking-wider border-b border-gray-100 pb-2 mb-2">Veri Ambarı Konsolu</h3>
      <div id="console-list" class="flex-1 overflow-y-auto space-y-1.5 text-[11px] font-mono text-gray-500">
        <div class="italic text-gray-400">Algoritma henüz çalıştırılmadı. Test sonuçları burada listelenecek.</div>
      </div>
    </div>

  </div>
</main>

<footer class="bg-white border-t border-gray-200 py-4 text-center text-xs text-gray-500">
  Veri ve Yapay Zeka Simülasyon Serisi • Ders 2
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const codeInput = document.getElementById('code-input');
    const runBtn = document.getElementById('run-code-btn');
    const helpBtn = document.getElementById('help-btn');
    const consoleList = document.getElementById('console-list');
    const feedback = document.getElementById('feedback');
    const scoreDisplay = document.getElementById('score');

    // API'den gelen simüle edilmiş nesne dizisi
    const testData = [
      { isim: "Ahmet", yas: 24, aktif: true, dogruSonuc: true },
      { isim: "Mehmet", yas: 16, aktif: true, dogruSonuc: false }, // Yaşı küçük
      { isim: "Ayşe", yas: 32, aktif: false, dogruSonuc: false },  // Aktif değil
      { isim: "Can", yas: 19, aktif: true, dogruSonuc: true },
      { isim: "Elif", yas: 17, aktif: false, dogruSonuc: false }, // Aktif değil ve yaşı küçük (Sınır testi)
      { isim: "Zeynep", yas: 45, aktif: true, dogruSonuc: true }
    ];

    helpBtn.addEventListener('click', () => {
      codeInput.value = `if (kullanici.aktif === false) {\n    return false;\n} else if (kullanici.yas >= 18) {\n    return true;\n} else {\n    return false;\n}`;
    });

    runBtn.addEventListener('click', () => {
      consoleList.innerHTML = "";
      let correctCount = 0;
      const userCode = codeInput.value.trim();

      if (!userCode) {
        showFeedback("Lütfen önce editör alanına kodunuzu yazın.", "error");
        return;
      }

      try {
        // Kullanıcı kodunu çalıştırılabilir fonksiyon nesnesine çeviriyoruz
        const userFunction = new Function('kullanici', userCode);

        testData.forEach(item => {
          // Fonksiyona parametre olarak sadece tek bir kullanıcı nesnesi gönderiyoruz
          const userResult = userFunction({ yas: item.yas, aktif: item.aktif });

          const logLine = document.createElement('div');
          logLine.className = "p-1.5 rounded text-[11px] border";

          // Geri dönüş değerinin boolean (true/false) olup olmadığını kontrol et
          if (userResult === item.dogruSonuc) {
            correctCount++;
            logLine.classList.add("bg-green-50", "border-green-100", "text-green-800");
            logLine.innerHTML = `[OK] <strong>${item.isim}</strong> -> Islem: ${userResult}`;
          } else {
            logLine.classList.add("bg-red-50", "border-red-100", "text-red-800");
            logLine.innerHTML = `[HATA] <strong>${item.isim}</strong> -> Beklenen: ${item.dogruSonuc}, Donen: ${userResult}`;
          }
          consoleList.appendChild(logLine);
        });

        scoreDisplay.innerText = correctCount;

        if (correctCount === 6) {
          showFeedback("Mükemmel! API nesnelerini filtreleyen algoritmanız sorunsuz çalıştı. Model eğitimi için veriler hazır.", "success");
        } else {
          showFeedback(`Kod çalıştı fakat filtreleme kurallarında açıklar var. Başarı: ${correctCount}/6. Yaş ve aktiflik durumlarını ayrı ayrı kontrol edin.`, "error");
        }

      } catch (error) {
        showFeedback(`Sözdizimi Hatası: Kod yazımında bir hata var. Nesne özelliklerini (kullanici.yas gibi) doğru yazdığınızdan emin olun.`, "syntax");

        const errorLine = document.createElement('div');
        errorLine.className = "p-2 bg-red-900 text-red-200 text-[10px] rounded font-mono";
        errorLine.innerText = `[HATA KONSOLU]: ${error.message}`;
        consoleList.appendChild(errorLine);
      }
    });

    function showFeedback(message, type) {
      feedback.classList.remove('hidden', 'bg-green-100', 'text-green-800', 'bg-amber-100', 'text-amber-800', 'bg-red-100', 'text-red-800');
      feedback.innerText = message;

      if (type === 'success') {
        feedback.classList.add('bg-green-100', 'text-green-800');
      } else if (type === 'error') {
        feedback.classList.add('bg-amber-100', 'text-amber-800');
      } else {
        feedback.classList.add('bg-red-100', 'text-red-800');
      }
    }
  });
</script>
</body>
</html>
