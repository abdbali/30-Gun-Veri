<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ders 2: API Veri Entegrasyonu Simülasyonu</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 font-sans text-gray-800 antialiased min-h-screen flex flex-col">

<header class="bg-white border-b border-gray-200 py-6 px-8 shadow-xs">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
    <div>
      <span class="text-xs font-semibold text-blue-600 tracking-wider uppercase">Modül 1: Veri Okuryazarlığı</span>
      <h1 class="text-2xl font-bold text-gray-900 mt-1">Ders 2: API'den Veri Çekme Simülasyonu (JSON Dönüşümü)</h1>
    </div>
    <div id="status-badge" class="bg-gray-100 text-gray-600 px-4 py-2 rounded-lg font-medium text-sm border border-gray-200">
      Bağlantı: Bekleniyor
    </div>
  </div>
</header>

<main class="flex-1 max-w-6xl w-full mx-auto p-6 grid grid-cols-1 lg:grid-cols-3 gap-6">

  <div class="lg:col-span-1 bg-white p-6 rounded-2xl border border-gray-200 shadow-xs flex flex-col justify-between">
    <div>
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Gerçek İş Senaryosu</h2>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">
        Şirketinin lojistik departmanı, hava durumunun teslimat sürelerine etkisini incelemek istiyor. Senden istenen, bir meteoroloji istasyonunun **API (Uygulama Programlama Arayüzü)** uç noktasına bağlanarak anlık verileri çekmen ve sistemin anlayacağı yapıya dönüştürmen.
      </p>

      <div class="border-l-4 border-blue-500 bg-blue-50 p-4 rounded-r-xl mb-4">
        <h3 class="text-sm font-semibold text-blue-900 mb-1">Bilgi Notu</h3>
        <p class="text-xs text-blue-800 leading-relaxed">
          Yapany zeka ve veri sistemleri ham web sayfalarını okuyamaz. Bunun yerine sistemler arasında standart bir veri formatı olan <strong>JSON (JavaScript Object Notation)</strong> yapısı kullanılır. JSON, verileri anahtar-değer (key-value) çiftleri halinde tutar.
        </p>
      </div>

      <h3 class="text-sm font-semibold text-gray-900 mb-2">Görevin:</h3>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">
        1. "API İsteği Gönder" butonuna basarak sunucudan ham JSON verisini çağırın.<br>
        2. Gelen karmaşık kodu analiz edin ve "Veriyi Tabloya Dönüştür" butonu ile yapılandırılmış rapora çevirin.
      </p>
    </div>

    <div class="space-y-3">
      <button id="fetch-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-5 py-3 rounded-xl transition shadow-xs cursor-pointer text-center">
        API İsteği Gönder (Fetch)
      </button>
      <button id="parse-btn" disabled class="w-full bg-gray-200 text-gray-400 font-medium text-sm px-5 py-3 rounded-xl transition text-center cursor-not-allowed">
        Veriyi Tabloya Dönüştür (JSON.parse)
      </button>
    </div>
  </div>

  <div class="lg:col-span-2 flex flex-col gap-6">

    <div class="bg-gray-900 rounded-2xl p-6 border border-gray-800 shadow-lg flex-1 flex flex-col min-h-[250px]">
      <div class="flex justify-between items-center mb-3">
        <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Sunucu Ham Çıktısı (JSON Konsolu)</span>
        <span id="console-status" class="text-xs text-gray-500">Veri Yok</span>
      </div>
      <div class="flex-1 bg-gray-950 p-4 rounded-xl border border-gray-800 font-mono text-xs text-green-400 overflow-y-auto max-h-[250px]">
        <pre id="json-output">// API isteği bekleniyor...</pre>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-6 border border-gray-200 shadow-xs min-h-[250px] flex flex-col">
      <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Yapılandırılmış İş Raporu</h3>
      <div class="flex-1 overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm text-left">
          <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
          <tr>
            <th class="px-4 py-3 font-semibold">Şehir</th>
            <th class="px-4 py-3 font-semibold">Sıcaklık (°C)</th>
            <th class="px-4 py-3 font-semibold">Nem (%)</th>
            <th class="px-4 py-3 font-semibold">Durum</th>
            <th class="px-4 py-3 font-semibold">Lojistik Risk</th>
          </tr>
          </thead>
          <tbody id="table-body" class="divide-y divide-gray-200 text-gray-700">
          <tr>
            <td colspan="5" class="px-4 py-8 text-center text-gray-400 italic">Dönüştürülecek veri bekleniyor.</td>
          </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</main>

<footer class="bg-white border-t border-gray-200 py-4 text-center text-xs text-gray-500">
  Veri ve Yapay Zeka Simülasyon Serisi • Ders 2
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const fetchBtn = document.getElementById('fetch-btn');
    const parseBtn = document.getElementById('parse-btn');
    const jsonOutput = document.getElementById('json-output');
    const tableBody = document.getElementById('table-body');
    const statusBadge = document.getElementById('status-badge');
    const consoleStatus = document.getElementById('console-status');

    // Simüle edilen Mock API Verisi
    const mockWeatherData = [
      { "sehir": "Istanbul", "sicaklik": 24, "nem": 65, "durum": "Yagmurlu", "risk": "Orta" },
      { "sehir": "Ankara", "sicaklik": 18, "nem": 40, "durum": "Acik", "risk": "Dusuk" },
      { "sehir": "Izmir", "sicaklik": 29, "nem": 55, "durum": "Acik", "risk": "Dusuk" },
      { "sehir": "Erzurum", "sicaklik": -2, "nem": 90, "durum": "Yogun Kar", "risk": "Yuksek" },
      { "sehir": "Antalya", "sicaklik": 32, "nem": 75, "durum": "Nemli", "risk": "Dusuk" }
    ];

    let rawJsonString = "";

    // 1. API İstek Simülasyonu (Fetch)
    fetchBtn.addEventListener('click', () => {
      jsonOutput.innerText = "// Sunucuya baglaniliyor...";
      statusBadge.className = "bg-amber-50 text-amber-700 px-4 py-2 rounded-lg font-medium text-sm border border-amber-100";
      statusBadge.innerText = "Bağlantı: İstek Gönderildi";

      setTimeout(() => {
        // Veriyi string (ham metin) formatına çevirip ekrana basıyoruz (Gerçek API gibi)
        rawJsonString = JSON.stringify(mockWeatherData, null, 4);
        jsonOutput.innerText = rawJsonString;

        consoleStatus.innerText = "200 OK (Veri Alındı)";
        consoleStatus.classList.remove('text-gray-500');
        consoleStatus.classList.add('text-green-400');

        statusBadge.className = "bg-green-50 text-green-700 px-4 py-2 rounded-lg font-medium text-sm border border-green-100";
        statusBadge.innerText = "Bağlantı: Başarılı";

        // İkinci butonu aktif et
        parseBtn.removeAttribute('disabled');
        parseBtn.className = "w-full bg-gray-800 hover:bg-gray-950 text-white font-medium text-sm px-5 py-3 rounded-xl transition text-center cursor-pointer shadow-xs";
      }, 1000);
    });

    // 2. Veriyi Ayrıştırma ve Tabloya Basma Simülasyonu (JSON.parse)
    parseBtn.addEventListener('click', () => {
      if (!rawJsonString) return;

      // String veriyi tekrar iterate edilebilir JS objesine dönüştürüyoruz
      const parsedData = JSON.parse(rawJsonString);

      // Tabloyu temizle
      tableBody.innerHTML = "";

      // Verileri satır satır ekle
      parsedData.forEach(item => {
        const row = document.createElement('tr');

        // Risk durumuna göre dinamik badge rengi ayarla
        let riskColor = "text-green-700 bg-green-50 border border-green-100";
        if (item.risk === "Orta") riskColor = "text-amber-700 bg-amber-50 border border-amber-100";
        if (item.risk === "Yuksek") riskColor = "text-red-700 bg-red-50 border border-red-100";

        row.innerHTML = `
                        <td class="px-4 py-3 font-medium text-gray-900">${item.sehir}</td>
                        <td class="px-4 py-3">${item.sicaklik}</td>
                        <td class="px-4 py-3">%${item.nem}</td>
                        <td class="px-4 py-3">${item.durum}</td>
                        <td class="px-4 py-3">
                            <span class="px-2.5 py-1 rounded-md text-xs font-semibold ${riskColor}">
                                ${item.risk}
                            </span>
                        </td>
                    `;
        tableBody.appendChild(row);
      });

      // İşlem bitince parse butonunu pasifize et
      parseBtn.setAttribute('disabled', 'true');
      parseBtn.className = "w-full bg-gray-200 text-gray-400 font-medium text-sm px-5 py-3 rounded-xl transition text-center cursor-not-allowed";
      fetchBtn.innerText = "Yeniden İstek At";
    });
  });
</script>
</body>
</html>
